# Jellyfin MCP Server - Environment Variables
# Copy to .env and populate with actual values
# DO NOT commit .env to git

# Jellyfin API Key (required)
# Dashboard → Advanced → API Keys
JELLYFIN_API_KEY=your_jellyfin_api_key_here

# Jellyfin Server URL — e.g. http://YOUR_SERVER:8096 (use https://YOUR_SERVER:8920 only if HTTPS is enabled in Jellyfin)
JELLYFIN_URL=http://YOUR_SERVER:8096

# Jellyfin User ID (optional, auto-detected if not set)
# JELLYFIN_USER_ID=

# Bearer token for HTTP transport / docker-compose (required when binding a
# non-localhost address). Generate a long random secret.
# HTTP_TOKEN=
